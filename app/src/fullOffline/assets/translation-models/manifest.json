{
  "pack": "goodzh-full-offline-translation",
  "version": "1.2",
  "engine": "onnx-marian-quantized",
  "runtime": "onnxruntime-android",
  "pivotRoutes": ["en", "zh"],
  "requiredFiles": [
    "manifest.json",
    "encoder_model_quantized.onnx",
    "decoder_model_quantized.onnx",
    "tokenizer.json",
    "vocab.json",
    "config.json",
    "generation_config.json",
    "license.txt"
  ],
  "directions": [
    {
      "id": "en-zh",
      "name": "英文转中文",
      "source": "en",
      "target": "zh",
      "repository": "onnx-community/opus-mt-en-zh",
      "license": "CC-BY 4.0",
      "status": "ready"
    },
    {
      "id": "zh-en",
      "name": "中文转英文",
      "source": "zh",
      "target": "en",
      "repository": "onnx-community/opus-mt-zh-en",
      "license": "CC-BY 4.0",
      "status": "ready"
    },
    {
      "id": "en-ja",
      "name": "英文转日文",
      "source": "en",
      "target": "ja",
      "repository": "Xenova/opus-mt-en-jap",
      "license": "CC-BY 4.0",
      "status": "ready"
    },
    {
      "id": "ja-en",
      "name": "日文转英文",
      "source": "ja",
      "target": "en",
      "repository": "Xenova/opus-mt-jap-en",
      "license": "CC-BY 4.0",
      "status": "ready"
    },
    {
      "id": "ko-en",
      "name": "韩文转英文",
      "source": "ko",
      "target": "en",
      "repository": "Xenova/opus-mt-ko-en",
      "license": "CC-BY 4.0",
      "status": "ready"
    },
    {
      "id": "en-ko",
      "name": "英文转韩文",
      "source": "en",
      "target": "ko",
      "license": "CC-BY 4.0",
      "status": "missing-public-onnx-export"
    }
  ]
}
